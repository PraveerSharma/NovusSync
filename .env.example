# Synthetic/local-only bootstrap values. Deployed values belong in Vercel.
NODE_ENV=development
APP_ENV=local
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://synthetic.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_synthetic_only
RELEASE_ID=local-development
LOG_LEVEL=debug
EXTERNAL_ACTIONS_MODE=deny
USE_FAKE_ADAPTERS=true
LIVE_PROVIDER_TESTS=false
AUTH_ACCESS_MODE=disabled

# PostgreSQL uses separately authorized managed Supabase projects; no local service is started.
# TEST_DATABASE_URL is required by pnpm verify and must target an isolated synthetic test project.
DATABASE_URL=
DATABASE_DIRECT_URL=
DATABASE_SHADOW_URL=
TEST_DATABASE_URL=

# Future tenant credential encryption. Never configure both values together.
# Use AWS KMS outside isolated local/test work.
CREDENTIAL_KMS_KEY_ID=
CREDENTIAL_ENCRYPTION_KEY=
