    "@novussync/ui": "workspace:*",
    "@supabase/ssr": "0.12.3",
    "@supabase/supabase-js": "2.110.7",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "24.13.3",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "eslint": "10.0.0",
    "postcss": "8.5.19",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3"
  }
