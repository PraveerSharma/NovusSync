{
  "name": "@novussync/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./testing": "./src/testing/fixtures.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src scripts drizzle.config.ts drizzle.migrate.config.ts --max-warnings=0",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:generate:guards": "drizzle-kit generate --custom --name=foundation_guards --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.migrate.config.ts",
    "db:reset": "node scripts/reset.mjs && drizzle-kit migrate --config=drizzle.migrate.config.ts && node scripts/seed.mjs",
    "db:seed": "node scripts/seed.mjs",
    "db:status": "node scripts/status.mjs",
    "test": "vitest run src/*.integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@novussync/application": "workspace:*",
    "@novussync/domain": "workspace:*",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
